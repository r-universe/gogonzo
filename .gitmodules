[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "marimekko"]
	path = marimekko
	url = https://github.com/gogonzo/marimekko
[submodule "runner"]
	path = runner
	url = https://github.com/gogonzo/runner
[submodule "sport"]
	path = sport
	url = https://github.com/gogonzo/sport
